# Renderer-only environment. Vite exposes any var starting with VITE_ to the
# browser bundle. All other secrets stay server-side in the orchestrator.

# WebSocket endpoint of the @friday/orchestrator process.
# Local dev: leave the default. Production: set to wss://your-domain.
VITE_ORCHESTRATOR_URL=ws://127.0.0.1:8787

# Wake word (OPTIONAL). Leave empty to start each turn manually
# with Space / the on-screen Wake button.
VITE_PICOVOICE_ACCESS_KEY=
VITE_PORCUPINE_KEYWORD=jarvis

# TTS engine.
#   "browser" — free, uses the browser's built-in speechSynthesis API
#   "server"  — plays orchestrator-streamed PCM (requires ElevenLabs)
VITE_TTS_MODE=browser
# Optional: force a specific OS voice. Find your voice URIs in DevTools:
#   speechSynthesis.getVoices().forEach(v => console.log(v.voiceURI, v.name, v.lang))
# Then paste one here, e.g. Microsoft Aria Online (Natural) - English (United States)
VITE_TTS_VOICE=
