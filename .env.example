# =========================================================================
# PROJECT FRIDAY — environment configuration
# Copy this file to `.env` and fill in real values.
# =========================================================================

# --- AWS Bedrock (Claude + Cohere embeddings) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Optional — only needed if your account uses temporary STS credentials.
AWS_SESSION_TOKEN=

# Claude model served via Bedrock. Sonnet 3 by default.
# Other options: anthropic.claude-3-haiku-20240307-v1:0
#                anthropic.claude-3-opus-20240229-v1:0
#                anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
FRIDAY_MAX_TOKENS=4096

# Cohere multilingual embedding model on Bedrock (1024-dim).
BEDROCK_EMBEDDING_MODEL_ID=cohere.embed-multilingual-v3

# --- Deepgram (streaming STT) ---
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en-US

# --- ElevenLabs (streaming TTS — OPTIONAL) ---
# Leave ELEVENLABS_API_KEY empty (or set FRIDAY_DISABLE_TTS=true) to run in
# text-only mode. The pipeline still streams the assistant's reply to the
# renderer's transcript pane; you just don't hear it spoken.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_turbo_v2_5
FRIDAY_DISABLE_TTS=false

# --- Picovoice Porcupine (wake word — OPTIONAL) ---
# If left empty, hands-free wake word is disabled. You start each turn
# manually with the Space key or the on-screen "Wake" button. The full
# STT -> Claude -> TTS pipeline behaves identically either way.
# Get a free personal-use key at https://console.picovoice.ai
PICOVOICE_ACCESS_KEY=
PORCUPINE_KEYWORD=jarvis

# --- Postgres + pgvector (memory) ---
DATABASE_URL=postgres://postgres:your_password@localhost:5432/db_name
PGVECTOR_DIM=1024

# --- Orchestrator transport ---
ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_PORT=8787

# --- Electron / runtime ---
FRIDAY_PREFERRED_DISPLAY=secondary
FRIDAY_FULLSCREEN=true
FRIDAY_DEV_TOOLS=false

# --- Logging ---
LOG_LEVEL=info
